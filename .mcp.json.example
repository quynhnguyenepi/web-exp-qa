{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    },
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-figma"
      ],
      "env": {
        "FIGMA_PERSONAL_ACCESS_TOKEN": "YOUR_FIGMA_TOKEN_HERE"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "YOUR_CONTEXT7_API_KEY_HERE"
      ]
    },
    "atlassian": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-atlassian",
        "--jira-url", "https://optimizely-ext.atlassian.net",
        "--jira-username", "YOUR_EMAIL@optimizely.com",
        "--jira-token", "YOUR_ATLASSIAN_TOKEN_HERE",
        "--toolsets", "all"
      ]
    },
    "serena": {
      "type": "stdio",
      "command": "serena-mcp-server",
      "args": [
        "--project-from-cwd"
      ]
    }
  }
}
